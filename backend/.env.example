# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB (Local with Compass)
MONGO_URI=mongodb://localhost:27017/portfolio

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Optional SMTP Configuration (use this instead of EMAIL_USER/EMAIL_PASS)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_ALLOW_NO_AUTH=false

# Note:
# - Anyone can submit the contact form (public route, no login required).
# - EMAIL_USER/SMTP_USER are server transport credentials, not frontend user credentials.
# - Set SMTP_ALLOW_NO_AUTH=true only for trusted local relays (e.g. MailHog), not public production SMTP.

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com

# Frontend URL (for CORS)
FRONTEND_URL=https://portfolio-rishu.vercel.app

# Admin Email (for notifications)
ADMIN_EMAIL=admin@example.com
